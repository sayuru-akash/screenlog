generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Better Auth tables
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  verifications Verification[]

  shows           UserShow[]
  movies          UserMovie[]
  episodeProgress EpisodeProgress[]
  activities      Activity[]
  preferences     UserPreference?

  @@map("user")
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  userId     String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([identifier, value])
  @@map("verification")
}

// App content tables
model Show {
  id           String   @id @default(cuid())
  tmdbId       Int?     @unique
  tvMazeId     Int?     @unique
  title        String
  overview     String?
  posterPath   String?
  backdropPath String?
  firstAirDate DateTime?
  status       String?
  type         String   @default("tv")
  genres       String[] @default([])
  language     String?
  network      String?
  runtime      Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  seasons   Season[]
  userShows UserShow[]

  @@map("show")
}

model Season {
  id           String   @id @default(cuid())
  showId       String
  seasonNumber Int
  name         String?
  overview     String?
  posterPath   String?
  airDate      DateTime?
  episodeCount Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  show     Show      @relation(fields: [showId], references: [id], onDelete: Cascade)
  episodes Episode[]

  @@unique([showId, seasonNumber])
  @@map("season")
}

model Episode {
  id            String   @id @default(cuid())
  seasonId      String
  episodeNumber Int
  seasonNumber  Int
  name          String
  overview      String?
  stillPath     String?
  airDate       DateTime?
  runtime       Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  season   Season            @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  progress EpisodeProgress[]

  @@unique([seasonId, episodeNumber])
  @@map("episode")
}

model Movie {
  id           String   @id @default(cuid())
  tmdbId       Int?     @unique
  title        String
  overview     String?
  posterPath   String?
  backdropPath String?
  releaseDate  DateTime?
  runtime      Int?
  genres       String[] @default([])
  language     String?
  status       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userMovies UserMovie[]

  @@map("movie")
}

enum ShowStatus {
  PLAN_TO_WATCH
  WATCHING
  CAUGHT_UP
  COMPLETED
  PAUSED
  DROPPED
}

enum MovieStatus {
  PLAN_TO_WATCH
  WATCHED
  FAVOURITE
  DROPPED
}

model UserShow {
  id        String     @id @default(cuid())
  userId    String
  showId    String
  status    ShowStatus @default(PLAN_TO_WATCH)
  addedAt   DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  show Show @relation(fields: [showId], references: [id], onDelete: Cascade)

  @@unique([userId, showId])
  @@map("user_show")
}

model UserMovie {
  id        String      @id @default(cuid())
  userId    String
  movieId   String
  status    MovieStatus @default(PLAN_TO_WATCH)
  addedAt   DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@map("user_movie")
}

model EpisodeProgress {
  id        String   @id @default(cuid())
  userId    String
  episodeId String
  watchedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([userId, episodeId])
  @@map("episode_progress")
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  type      String
  showId    String?
  movieId   String?
  episodeId String?
  metadata  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("activity")
}

model UserPreference {
  id        String   @id @default(cuid())
  userId    String   @unique
  theme     String   @default("system")
  region    String?
  language  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preference")
}
